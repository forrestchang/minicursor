# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model to use (default: claude-sonnet-4-6)
# MINICURSOR_MODEL=claude-sonnet-4-6

# Optional: port (default: 5173)
# PORT=5173

# Optional: root folder to edit (default: current working directory)
# MINICURSOR_ROOT=/absolute/path/to/project
